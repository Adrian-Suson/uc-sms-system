--- This file contains environment variables for the server configuration. ---

--- PORT ---
PORT=9000
--- Database ---
DB_HOST=localhost
DB_USER=root
DB_PASS=password
DB_NAME=iot_database
DB_PORT=3306
DB_DIALECT=mysql
--- JWT ---
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
--- CORS ---
CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true
--- Other ---
LOG_LEVEL=info
API_PREFIX=/api
REQUEST_TIMEOUT=5000
MAX_PAYLOAD_SIZE=1mb
RATE_LIMIT_WINDOW_MS=15*60*1000
RATE_LIMIT_MAX=100
SESSION_SECRET=your_session_secret
SESSION_LIFETIME=2h
NODE_ENV=development
DEBUG=false
APP_NAME=IOTServer
APP_VERSION=1.0.0
